# WebAgent 环境变量配置示例。
# 复制为 .env 并按需修改；agent/browser_tools.py 通过 python-dotenv 自动加载。

# --- LLM 调用凭证（必填，browser_extract / ActionSelector 等模块调用 Anthropic API 需要）---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- AgentConfig 可选覆盖项 ---
# 以下变量均为可选：未设置时使用 agent/config.py 中 AgentConfig 的 dataclass 默认值。
# 只有显式调用 AgentConfig.from_env() 时才会读取这些变量；
# 直接 AgentConfig() 构造不受这些变量影响。
# 变量名规则：WEBAGENT_<字段名大写>，与 AgentConfig 的 13 个字段一一对应。

# 使用的模型（对应 AgentConfig.model，默认 claude-sonnet-4-6）
WEBAGENT_MODEL=claude-sonnet-4-6

# 单次任务最大执行步数（对应 AgentConfig.max_steps，默认 15）
WEBAGENT_MAX_STEPS=15

# 连续失败次数上限，超过则终止任务（对应 AgentConfig.max_fail，默认 3）
WEBAGENT_MAX_FAIL=3

# 每步之间的等待间隔，单位秒（对应 AgentConfig.step_delay，默认 0.5）
WEBAGENT_STEP_DELAY=0.5

# observe() 返回的交互元素最大数量（对应 AgentConfig.obs_max_elements，默认 20）
WEBAGENT_OBS_MAX_ELEMENTS=20

# observe() 返回的可见文本摘要最大字符数（对应 AgentConfig.obs_text_limit，默认 500）
WEBAGENT_OBS_TEXT_LIMIT=500

# LLM 单次请求超时时间，单位秒（对应 AgentConfig.llm_timeout，默认 30）
WEBAGENT_LLM_TIMEOUT=30

# Playwright 浏览器操作超时时间，单位毫秒（对应 AgentConfig.browser_timeout，默认 15000）
WEBAGENT_BROWSER_TIMEOUT=15000

# browser_open 遇到超时时的额外重试次数，不含首次尝试（对应 AgentConfig.open_retry，默认 2）
# 触发重试的错误类型为 PlaywrightTimeoutError（page.goto 超时），不含首次尝试；
# 即 open_retry=2 表示首次超时后再最多重试 2 次，总共最多 3 次 page.goto 调用。
WEBAGENT_OPEN_RETRY=2

# LLM 请求失败后的重试次数（对应 AgentConfig.llm_retry，默认 3）
WEBAGENT_LLM_RETRY=3

# 遭遇 429 速率限制错误时的等待秒数（对应 AgentConfig.rate_limit_delay，默认 60）
# 免费模型（如 GLM-4-Flash）的速率窗口通常为 1 分钟，默认 60s 已能覆盖大多数情况。
# 付费模型一般不会触发 429，无需修改此项。
WEBAGENT_RATE_LIMIT_DELAY=60

# 每个 eval case 执行完毕后的预防性延迟（秒）（对应 AgentConfig.case_delay，默认 0）
# 免费模型建议设为 30~60（即 1 分钟内最多 1±2 个 case，避免触发频率限制）。
# 付费模型保持默认 0 即可，不影响运行速度。
# 示例：WEBAGENT_CASE_DELAY=30
WEBAGENT_CASE_DELAY=0

# 执行轨迹（trace.jsonl / report.json / 截图）的根目录（对应 AgentConfig.trace_dir，默认 traces）
WEBAGENT_TRACE_DIR=traces
